APP_NAME=chat-model-serving-real
APP_ENV=real
LOG_LEVEL=INFO

LLM_PROVIDER=vllm
TTS_PROVIDER=gptsovits
SESSION_BACKEND=redis

VLLM_MODEL=default
VLLM_TEMPERATURE=0.7
VLLM_MAX_TOKENS=256
VLLM_CONNECT_TIMEOUT_SEC=5.0
VLLM_READ_TIMEOUT_SEC=60.0

GPT_SOVITS_CONNECT_TIMEOUT_SEC=5.0
GPT_SOVITS_READ_TIMEOUT_SEC=60.0

HTTP_RETRY_COUNT=1
HTTP_RETRY_BASE_DELAY_SEC=0.2
HTTP_RETRY_MAX_DELAY_SEC=2.0
HTTP_RETRY_JITTER_ENABLED=true
HTTP_RETRY_JITTER_RATIO=0.25
HTTP_RETRY_TOTAL_TIMEOUT_SEC=8.0
LLM_HTTP_RETRY_COUNT=-1
TTS_HTTP_RETRY_COUNT=-1
TTS_SYNTHESIS_IDEMPOTENT=false

REDIS_URL=redis://redis:6379/0
SESSION_TTL_SEC=3600
POSTGRES_DSN=postgresql://app:app@postgres:5432/app
POSTGRES_MIN_POOL_SIZE=1
POSTGRES_MAX_POOL_SIZE=5
SESSION_EXPIRATION_SEC=86400
MAX_HISTORY_TURNS=10

REQUEST_TIMEOUT_SEC=30.0
STREAM_TOTAL_TIMEOUT_SEC=60.0
STREAM_CHUNK_SIZE=24

AUTH_ENABLED=false
AUTH_DEFAULT_TENANT=public
AUTH_TENANT_API_KEYS=

RATE_LIMIT_ENABLED=false
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_REQUESTS_PER_WINDOW=120
RATE_LIMIT_TENANT_OVERRIDES=
RATE_LIMIT_FAIL_OPEN=true

# ===== Real provider runtime parameters (compose reference) =====
VLLM_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.9
HF_CACHE_DIR=./models/hf-cache

# GPT-SoVITS image/model path should match your runtime environment.
GPT_SOVITS_IMAGE=breakstring/gpt-sovits:latest
GPT_SOVITS_MODEL_DIR=./models/gpt-sovits
