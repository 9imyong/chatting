APP_NAME=chat-model-serving
APP_ENV=dev
LOG_LEVEL=INFO

LLM_PROVIDER=stub
TTS_PROVIDER=stub
SESSION_BACKEND=memory

VLLM_BASE_URL=http://vllm:8001
VLLM_MODEL=default
VLLM_TEMPERATURE=0.7
VLLM_MAX_TOKENS=256
VLLM_CONNECT_TIMEOUT_SEC=2.0
VLLM_READ_TIMEOUT_SEC=10.0

GPT_SOVITS_BASE_URL=http://gpt-sovits:9880
GPT_SOVITS_CONNECT_TIMEOUT_SEC=2.0
GPT_SOVITS_READ_TIMEOUT_SEC=12.0

HTTP_RETRY_COUNT=2
HTTP_RETRY_BASE_DELAY_SEC=0.2
HTTP_RETRY_MAX_DELAY_SEC=2.0
HTTP_RETRY_JITTER_ENABLED=true
HTTP_RETRY_JITTER_RATIO=0.25
HTTP_RETRY_TOTAL_TIMEOUT_SEC=8.0
LLM_HTTP_RETRY_COUNT=-1
TTS_HTTP_RETRY_COUNT=-1
TTS_SYNTHESIS_IDEMPOTENT=false

REDIS_URL=redis://redis:6379/0
SESSION_TTL_SEC=3600
POSTGRES_DSN=postgresql://app:app@postgres:5432/app
POSTGRES_MIN_POOL_SIZE=1
POSTGRES_MAX_POOL_SIZE=5
# postgres backend uses expiration/cleanup strategy (not redis-style hard TTL).
SESSION_EXPIRATION_SEC=86400
MAX_HISTORY_TURNS=10

REQUEST_TIMEOUT_SEC=15.0
STREAM_TOTAL_TIMEOUT_SEC=30.0
STREAM_CHUNK_SIZE=12
